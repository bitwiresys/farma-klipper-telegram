{
  "name": "@farma/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "test": "vitest run",
    "bootstrap:printer": "tsx src/cli/bootstrap_printer.ts",
    "bootstrap:token": "tsx src/cli/bootstrap_token.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@farma/shared": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/websocket": "^11.0.0",
    "@prisma/client": "^6.3.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "telegraf": "^4.16.3",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.1",
    "@types/ws": "^8.18.1",
    "prisma": "^6.3.1",
    "vitest": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
