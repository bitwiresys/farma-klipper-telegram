# Backend dry-start config (example). Copy to .env and fill in real values.

NODE_ENV=development
PORT=3001
BASE_URL_PUBLIC=http://localhost:3001

# JWT for sessions between Frontend <-> Backend
JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING_32+

# Telegram
TELEGRAM_BOT_TOKEN=123456789:REPLACE_WITH_REAL_BOT_TOKEN
# Mini App URL (frontend). Local dev: http://localhost:3000. Prod: https://<your-vercel-domain>
TELEGRAM_WEBAPP_URL=http://localhost:3000
# Comma-separated Telegram user IDs that are allowed to use the bot.
TELEGRAM_ALLOWED_USER_IDS=123456789
TELEGRAM_AUTH_MAX_AGE_SEC=86400

# Used to encrypt Moonraker API keys in DB
PRINTER_API_KEY_ENC_KEY=CHANGE_ME_TO_LONG_RANDOM_STRING_32+

# Prisma
DATABASE_URL=file:./prod.db

# Files storage
FILES_DIR=./data
WS_BATCH_INTERVAL_MS=400

# Security
RATE_LIMIT_RPM=120
CORS_ORIGIN=http://localhost:3000
