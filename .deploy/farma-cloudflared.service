[Unit]
Description=Cloudflare Tunnel for Farma Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=onem
WorkingDirectory=/home/onem
EnvironmentFile=/etc/farma-cloudflared.env
TimeoutStopSec=5
ExecStart=/usr/bin/cloudflared tunnel --loglevel debug --no-autoupdate --protocol http2 --edge-ip-version 4 --ha-connections 4 run --token ${TUNNEL_TOKEN}
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
