# Backend
NODE_ENV=development
PORT=3001
BASE_URL_PUBLIC=http://localhost:3001
JWT_SECRET=change_me_min_16_chars

TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_WEBAPP_URL=https://example.com/
TELEGRAM_BOT_USERNAME=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_AUTH_MAX_AGE_SEC=86400

PRINTER_API_KEY_ENC_KEY=change_me_min_16_chars

# Prisma resolves file:./... relative to apps/backend/prisma
DATABASE_URL=file:./dev.db

FILES_DIR=./data
WS_BATCH_INTERVAL_MS=400
RATE_LIMIT_RPM=120
CORS_ORIGIN=*

# Frontend
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:3001
NEXT_PUBLIC_APP_VERSION=dev
# DEV-only UI toggles
NEXT_PUBLIC_DEV_ONLY=0
